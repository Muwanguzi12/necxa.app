{
  "name": "necxa-engagement-service",
  "version": "0.1.0",
  "description": "Mongo-backed engagement engine for NECXA",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p .",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests --runInBand",
    "ci:mongo-check": "node dist/ci-mongo-check.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pino": "^8.0.0",
    "mongodb": "^4.13.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "jose": "^4.15.9",
    "express-rate-limit": "^6.7.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "supertest": "^6.0.0",
    "@types/supertest": "^2.0.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/*.test.ts"]
  }
}
